# Copy to .env and replace values. JWT can be any long random string in dev.

# From Supabase: Project Settings → Database → Connect → ORM / Prisma
# Replace POSTGRES_ENCODED_PASSWORD (URL-encoded: e.g. $ → %24, & → %26)
# Pooler hostname is project-specific — copy verbatim from dashboard (often aws-0-<region>.pooler.supabase.com)

DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:POSTGRES_ENCODED_PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:POSTGRES_ENCODED_PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres"

JWT_SECRET="replace-with-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development

# After prisma db push, optional QA data:
#   npm run seed
# Deletes only rows with emails ending @committee-seed.demo, then inserts demo users + committee + 2 rounds + payments.
