# Supabase Postgres: direct host db.PROJECT.supabase.co:5432 is IPv6-only — many Windows LANs hit P1001 / registration failures.
# Fix: Dashboard → Connect → pick "Prisma" / ORMs → copy BOTH pooler URIs for YOUR project host (same ...pooler.supabase.com, not db.*).
# DATABASE_URL = Transaction mode, port 6543, MUST end with ?pgbouncer=true
# DIRECT_URL   = Session mode, port 5432 (used by prisma migrate / db push)
# Username for poolers is postgres.PROJECT_REF (see copied string), NOT plain "postgres".

# Verified pooler for this project (IPv4-capable): aws-1-ap-south-1
DATABASE_URL="postgresql://postgres.btyoualbwzmnvfepgwfo:C%24esyz_%26XeD62Dk@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.btyoualbwzmnvfepgwfo:C%24esyz_%26XeD62Dk@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"
JWT_SECRET="committee_mgmt_super_secret_jwt_key_2024_production"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
