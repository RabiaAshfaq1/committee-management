generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phone      String?
  cnic       String?  @unique
  password   String
  role       Role     @default(MEMBER)
  avatar     String?
  trustScore Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  committees       CommitteeMember[]
  payments         Payment[]
  organized        Committee[]       @relation("AdminCommittees")
  feedbackSent     Feedback[]        @relation("FeedbackFrom")
  feedbackReceived Feedback[]        @relation("FeedbackTo")
  badges           UserBadge[]
}

model Committee {
  id             String          @id @default(uuid())
  name           String
  description    String?
  totalSlots     Int
  monthlyAmount  Float
  startDate      DateTime
  durationMonths Int
  turnMethod     TurnMethod      @default(MANUAL)
  status         CommitteeStatus @default(ACTIVE)
  adminId        String
  createdAt      DateTime        @default(now())

  admin     User              @relation("AdminCommittees", fields: [adminId], references: [id])
  members   CommitteeMember[]
  rounds    Round[]
  feedbacks Feedback[]
}

model CommitteeMember {
  id          String   @id @default(uuid())
  userId      String
  committeeId String
  turnNumber  Int
  shareCount  Int      @default(1)
  shareAmount Float
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  committee Committee  @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@unique([userId, committeeId])
}

model Round {
  id                         String      @id @default(uuid())
  committeeId                String
  roundNumber                Int
  payoutUserId               String?
  status                     RoundStatus @default(PENDING)
  dueDate                    DateTime?
  /// Winner's proof of receiving payout (manual transfer reference)
  recipientTransactionId     String?
  createdAt                  DateTime    @default(now())

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  payments  Payment[]
  feedbacks Feedback[]
}

model Payment {
  id              String        @id @default(uuid())
  roundId         String
  memberId        String
  userId          String
  amount          Float
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  paidAt          DateTime?
  dueDate         DateTime?
  createdAt       DateTime      @default(now())

  round  Round           @relation(fields: [roundId], references: [id], onDelete: Cascade)
  member CommitteeMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id])

  @@index([roundId])
  @@index([userId])
}

model Feedback {
  id          String   @id @default(uuid())
  fromUserId  String
  toUserId    String
  committeeId String
  roundId     String?
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  fromUser  User      @relation("FeedbackFrom", fields: [fromUserId], references: [id])
  toUser    User      @relation("FeedbackTo", fields: [toUserId], references: [id])
  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  round     Round?    @relation(fields: [roundId], references: [id], onDelete: SetNull)
}

model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  icon        String
  color       String
  condition   String

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

enum Role {
  ADMIN
  MEMBER
}

enum CommitteeStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum RoundStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum TurnMethod {
  MANUAL
  SPIN
  BIDDING
  RANDOM
}
