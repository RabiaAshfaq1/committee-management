generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  cnic      String?  @unique
  password  String
  role      Role     @default(MEMBER)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  committees CommitteeMember[]
  organized  Committee[]       @relation("OrganizerCommittees")
}

model Committee {
  id             String          @id @default(uuid())
  name           String
  description    String?
  totalMembers   Int
  monthlyAmount  Float
  startDate      DateTime
  durationMonths Int
  turnAssignment TurnAssignment  @default(RANDOM)
  status         CommitteeStatus @default(ACTIVE)
  organizerId    String
  createdAt      DateTime        @default(now())

  organizer User              @relation("OrganizerCommittees", fields: [organizerId], references: [id])
  members   CommitteeMember[]
  rounds    Round[]
}

model CommitteeMember {
  id          String   @id @default(uuid())
  userId      String
  committeeId String
  turnNumber  Int
  createdAt   DateTime @default(now())

  user        User                     @relation(fields: [userId], references: [id])
  committee   Committee                @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  roundSplits RoundContributionSplit[]
}

/// How the monthly pool is formed (e.g. two people give 5k + 5k for a 10k month).
model RoundContributionSplit {
  id        String   @id @default(uuid())
  roundId   String
  memberId  String
  amount    Float
  createdAt DateTime @default(now())

  round  Round           @relation(fields: [roundId], references: [id], onDelete: Cascade)
  member CommitteeMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Round {
  id                  String      @id @default(uuid())
  committeeId         String
  roundNumber         Int
  payoutUserId        String?
  payoutAmount        Float?
  payoutTransactionId String?
  status              RoundStatus @default(PENDING)
  dueDate             DateTime?
  createdAt           DateTime    @default(now())

  committee          Committee                @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  contributionSplits RoundContributionSplit[]
}

enum Role {
  ORGANIZER
  MEMBER
}

enum CommitteeStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum RoundStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum TurnAssignment {
  RANDOM
  MANUAL
  BIDDING
}
